NODE_ENV=production
HOST=127.0.0.1
PORT=3000

# Public HTTPS origin used by the deployed site.
PUBLIC_ORIGIN=https://tercih.example.com
ALLOWED_ORIGINS=https://tercih.example.com

# Change all admin values before production.
ADMIN_EMAIL=admin@kurumunuz.com
ADMIN_NAME=Sistem Admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SESSION_SECRET=change-this-with-a-very-long-random-secret
ADMIN_TOKEN_TTL_MS=28800000

# In-memory rate limits.
ADMIN_LOGIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_LOGIN_RATE_LIMIT_MAX=8
PUBLIC_LEAD_RATE_LIMIT_WINDOW_MS=600000
PUBLIC_LEAD_RATE_LIMIT_MAX=20

# Audit retention. Set 0 to disable startup cleanup.
AUDIT_LOG_RETENTION_DAYS=180

# Real email delivery. Fill these to send admin messages via SMTP.
SMTP_TEST_MODE=false
SMTP_TEST_RECIPIENT=akilli-tercih-test@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_USER=mail@example.com
SMTP_PASS=change-this-mail-password
SMTP_FROM=mail@example.com
SMTP_FROM_NAME=Akilli Tercih Sistemi
SMTP_TIMEOUT_MS=15000

# SMS delivery. Textbelt supports a free test key flow; replace for production.
SMS_PROVIDER=textbelt
SMS_API_KEY=textbelt_test
SMS_TEST_MODE=true
SMS_TEST_PHONE=+15555555555
SMS_TEXTBELT_URL=https://textbelt.com/text
SMS_TIMEOUT_MS=15000
